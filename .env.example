# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Runtime (transaction pooler)
# Format: postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct DB connection (for Prisma migrate/studio)
# Format: postgresql://USER:PASSWORD@HOST:5432/DATABASE
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
